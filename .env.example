# Copy this to .env and fill in your values
# Never commit .env to git

# Azure OpenAI / Foundry endpoint
# Format: https://<account-name>.cognitiveservices.azure.com/
# Find it in Azure Portal: Cognitive Services resource → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://<account-name>.cognitiveservices.azure.com/

# Service Bus namespace host (only needed for Project 03 — Email Triage Agent)
# Format: <namespace>.servicebus.windows.net  (Entra ID auth — no connection string)
# SERVICE_BUS_NAMESPACE=<namespace>.servicebus.windows.net

# Vector store ID for knowledge grounding (only needed for Project 04 — Policy Chatbot)
# Format: vs-...  (from Foundry IQ knowledge, or openai.vector_stores.create)
# POLICY_VECTOR_STORE_ID=vs-xxxxxxxxxxxxxxxx

# Document Intelligence endpoint (only needed for Project 05 — Contract Clause Analyzer)
# Format: https://<account-name>.cognitiveservices.azure.com/  (Entra ID auth — no key)
# DOC_INTEL_ENDPOINT=https://<account-name>.cognitiveservices.azure.com/
