# Copy this to .env and fill in your values
# Never commit .env to git

# Azure OpenAI / Foundry endpoint
# Format: https://<account-name>.cognitiveservices.azure.com/
# Find it in Azure Portal: Cognitive Services resource → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://<account-name>.cognitiveservices.azure.com/

# Service Bus namespace host (only needed for Project 03 — Email Triage Agent)
# Format: <namespace>.servicebus.windows.net  (Entra ID auth — no connection string)
# SERVICE_BUS_NAMESPACE=<namespace>.servicebus.windows.net

# Vector store ID for knowledge grounding (only needed for Project 04 — Policy Chatbot)
# Format: vs-...  (from Foundry IQ knowledge, or openai.vector_stores.create)
# CHAT_MODEL: optional, defaults to "gpt-4.1-mini"
# POLICY_VECTOR_STORE_ID=vs-xxxxxxxxxxxxxxxx

# Document Intelligence endpoint (only needed for Project 05 — Contract Clause Analyzer)
# Format: https://<account-name>.cognitiveservices.azure.com/  (Entra ID auth — no key)
# DOC_INTEL_ENDPOINT=https://<account-name>.cognitiveservices.azure.com/

# Multi-Agent Incident Responder (Project 06) — Entra ID auth, no keys
# APP_INSIGHTS_WORKSPACE_ID: the Log Analytics / App Insights workspace (customer) ID (a GUID)
# SEARCH_ENDPOINT: your Azure AI Search endpoint (enable AAD: az search service update --auth-options aadOrApiKey)
# SEARCH_INDEX: optional, defaults to "runbooks"
# INCIDENT_MODEL: optional, defaults to "gpt-4.1"
# APP_INSIGHTS_WORKSPACE_ID=00000000-0000-0000-0000-000000000000
# SEARCH_ENDPOINT=https://<search-service>.search.windows.net
# SEARCH_INDEX=runbooks

# Data Pipeline QA Agent (Project 07) — Entra ID auth, no keys
# STORAGE_ACCOUNT: storage account name for baseline JSON history (Storage Blob Data Contributor)
# QA_MODEL: optional, defaults to "gpt-4.1-mini"
# TEAMS_WEBHOOK_URL: optional, Teams Incoming Webhook for alerts
# STORAGE_ACCOUNT=<storage-account-name>
# TEAMS_WEBHOOK_URL=https://<tenant>.webhook.office.com/...

# Voice Field Assistant (Project 08)
# Requires GPT-4o Realtime deployed on the AZURE_OPENAI_ENDPOINT above.
# SEARCH_ENDPOINT / SEARCH_KEY: Azure AI Search holding equipment-manual chunks
# SEARCH_INDEX: optional, defaults to "equipment-manuals"
# SEARCH_ENDPOINT=https://<search-service>.search.windows.net
# SEARCH_KEY=<search-admin-or-query-key>
# SEARCH_INDEX=equipment-manuals

# Competitive Intelligence Dashboard (Project 09) — Entra ID auth, no keys
# COSMOS_ENDPOINT: Cosmos DB account URL (Cosmos DB Built-in Data Contributor)
# INTEL_MODEL: optional, defaults to "gpt-4.1". Requires web grounding enabled in Foundry.
# COSMOS_ENDPOINT=https://<cosmos-account>.documents.azure.com:443/

# Agentic Approval Workflow (Project 10)
# COSMOS_ENDPOINT: decision audit-log account (Cosmos DB Built-in Data Contributor)
# POLICY_VECTOR_STORE_ID: Foundry IQ vector store with the policy docs (vs-...)
# FUNCTION_APP_BASE_URL / FUNC_KEY: callback URL + function key for the Teams Action.Http button
# SERVICE_BUS_CONNECTION_STRING: queue connection string (test harness)
# ENTRA_CLIENT_ID / ENTRA_CLIENT_SECRET / ENTRA_TENANT_ID: app registration for Microsoft Graph
# APPROVAL_MODEL: optional, defaults to "gpt-5.4-mini"
# COSMOS_ENDPOINT=https://<cosmos-account>.documents.azure.com:443/
# POLICY_VECTOR_STORE_ID=vs-xxxxxxxxxxxxxxxx
# FUNCTION_APP_BASE_URL=https://<func-app>.azurewebsites.net
# FUNC_KEY=<function-key>
# SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://<namespace>.servicebus.windows.net/;...
# ENTRA_CLIENT_ID=<app-client-id>
# ENTRA_CLIENT_SECRET=<app-client-secret>
# ENTRA_TENANT_ID=<tenant-id>

# Computer-Use Process Automator (Project 11)
# KEY_VAULT_NAME: vault holding target-app credentials (Key Vault Secrets User)
# COMPUTER_USE_MODEL: optional, defaults to "gpt-5.4"
# KEY_VAULT_NAME=<key-vault-name>

# Multi-Modal Quality Inspector (Project 12)
# SEARCH_ENDPOINT / SEARCH_KEY: Azure AI Search holding the defect catalog (vector index)
# COSMOS_ENDPOINT: inspection-results account (Cosmos DB Built-in Data Contributor)
# EVENT_HUB_CONNECTION_STRING: Event Hub the IoT images stream lands in
# EVENT_HUB_NAME: optional, defaults to "images-stream"
# DEFECT_THRESHOLD: optional, defaults to "0.75"
# SEARCH_ENDPOINT=https://<search-service>.search.windows.net
# SEARCH_KEY=<search-admin-or-query-key>
# COSMOS_ENDPOINT=https://<cosmos-account>.documents.azure.com:443/
# EVENT_HUB_CONNECTION_STRING=Endpoint=sb://<namespace>.servicebus.windows.net/;...
